#!/usr/bin/env bash

# ~/.aliases — 命令别名
# 基于 https://github.com/mathiasbynens/dotfiles

###############################################################################
# 导航                                                                        #
###############################################################################

alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ~="cd ~"
alias -- -="cd -"

# 常用目录
alias dl="cd ~/Downloads"
alias dt="cd ~/Desktop"
alias dc="cd ~/Documents"
alias dev="cd ~/Developer"

###############################################################################
# 列表 - 使用 eza 替代 ls                                                      #
###############################################################################

if command -v eza &> /dev/null; then
    alias ls="eza --icons --group-directories-first"
    alias l="eza -l --icons --group-directories-first"
    alias la="eza -la --icons --group-directories-first"
    alias ll="eza -l --icons --group-directories-first"
    alias lt="eza -T --icons --group-directories-first"  # 树形显示
    alias lta="eza -Ta --icons --group-directories-first"
else
    # Fallback to ls
    alias ls="ls -G"
    alias l="ls -lF"
    alias la="ls -laF"
    alias ll="ls -lF"
fi

###############################################################################
# Git                                                                         #
###############################################################################

alias g="git"
alias gs="git status"
alias ga="git add"
alias gaa="git add -A"
alias gc="git commit"
alias gcm="git commit -m"
alias gca="git commit --amend"
alias gp="git push"
alias gpl="git pull"
alias gf="git fetch"
alias gfa="git fetch --all"
alias gb="git branch"
alias gba="git branch -a"
alias gco="git checkout"
alias gcb="git checkout -b"
alias gd="git diff"
alias gds="git diff --staged"
alias gl="git log --oneline -20"
alias gla="git log --oneline --all --graph"
alias gst="git stash"
alias gstp="git stash pop"
alias grb="git rebase"
alias grbi="git rebase -i"

# 使用 lazygit（如果安装了）
if command -v lazygit &> /dev/null; then
    alias lg="lazygit"
fi

###############################################################################
# 现代 CLI 工具替代                                                            #
###############################################################################

# bat 替代 cat
if command -v bat &> /dev/null; then
    alias cat="bat --paging=never"
    alias catp="bat"  # 带分页
fi

# fd 替代 find
if command -v fd &> /dev/null; then
    alias find="fd"
fi

# ripgrep 替代 grep
if command -v rg &> /dev/null; then
    alias grep="rg"
fi

# dust 替代 du
if command -v dust &> /dev/null; then
    alias du="dust"
fi

# duf 替代 df
if command -v duf &> /dev/null; then
    alias df="duf"
fi

# procs 替代 ps
if command -v procs &> /dev/null; then
    alias ps="procs"
fi

# htop 替代 top
if command -v htop &> /dev/null; then
    alias top="htop"
fi

# tldr 替代 man (简化版)
if command -v tldr &> /dev/null; then
    alias help="tldr"
fi

###############################################################################
# 网络                                                                        #
###############################################################################

# 获取公网 IP
alias ip="curl -s https://api.ipify.org && echo"
alias ip4="curl -s https://api.ipify.org && echo"
alias ip6="curl -s https://api6.ipify.org && echo"

# 获取本地 IP
alias localip="ipconfig getifaddr en0"
alias ips="ifconfig -a | grep -o 'inet6\? \(addr:\)\?\s\?\(\(\([0-9]\+\.\)\{3\}[0-9]\+\)\|[a-fA-F0-9:]\+\)' | awk '{ sub(/inet6? (addr:)? ?/, \"\"); print }'"

# 刷新 DNS 缓存
alias flushdns="sudo dscacheutil -flushcache && sudo killall -HUP mDNSResponder && echo 'DNS cache flushed'"

# 显示活跃的网络连接
alias connections="lsof -i"

# 快速 HTTP 服务器
alias serve="python3 -m http.server 8000"

###############################################################################
# 系统                                                                        #
###############################################################################

# 一键更新所有包管理器
alias update="brew update && brew upgrade && brew cleanup"
alias updateall="brew update && brew upgrade && brew cleanup; npm update -g; pip3 install --upgrade pip"

# 清理 Homebrew
alias brewclean="brew cleanup -s && brew autoremove"

# 显示/隐藏 隐藏文件
alias showfiles="defaults write com.apple.finder AppleShowAllFiles -bool true && killall Finder"
alias hidefiles="defaults write com.apple.finder AppleShowAllFiles -bool false && killall Finder"

# 显示/隐藏 桌面图标
alias showdesktop="defaults write com.apple.finder CreateDesktop -bool true && killall Finder"
alias hidedesktop="defaults write com.apple.finder CreateDesktop -bool false && killall Finder"

# 重启 Finder
alias rf="killall Finder"

# 重启 Dock
alias rd="killall Dock"

# 清空废纸篓（所有挂载的卷）
alias emptytrash="sudo rm -rfv /Volumes/*/.Trashes; sudo rm -rfv ~/.Trash; sudo rm -rfv /private/var/log/asl/*.asl"

# 清理系统日志
alias cleanlogs="sudo rm -rfv /private/var/log/asl/*.asl"

# 重建 Spotlight 索引
alias reindex="sudo mdutil -E /"

# 锁屏
alias lock="pmset displaysleepnow"
alias afk="pmset displaysleepnow"

# 睡眠
alias sleep="pmset sleepnow"

###############################################################################
# 开发                                                                        #
###############################################################################

# Node.js / pnpm
alias p="pnpm"
alias pi="pnpm install"
alias pa="pnpm add"
alias pad="pnpm add -D"
alias pr="pnpm remove"
alias pd="pnpm dev"
alias pb="pnpm build"
alias pt="pnpm test"

# npm (fallback)
alias ni="npm install"
alias nr="npm run"
alias nrd="npm run dev"
alias nrb="npm run build"
alias nrt="npm run test"

# Python
alias py="python3"
alias pip="pip3"
alias venv="python3 -m venv .venv && source .venv/bin/activate"
alias activate="source .venv/bin/activate"

# Docker
alias d="docker"
alias dc="docker compose"
alias dcu="docker compose up"
alias dcd="docker compose down"
alias dcb="docker compose build"
alias dps="docker ps"
alias dpsa="docker ps -a"

###############################################################################
# AI 工具                                                                     #
###############################################################################

# Claude Code
alias c="claude"
alias cc="claude"

# OpenAI Codex
alias cx="codex"

###############################################################################
# 编辑器                                                                      #
###############################################################################

alias v="code"
alias code.="code ."
alias zshrc="code ~/.zshrc"
alias aliases="code ~/.aliases"

###############################################################################
# 杂项                                                                        #
###############################################################################

# 创建目录并进入
alias mkcd='function _mkcd(){ mkdir -p "$1" && cd "$1"; }; _mkcd'

# 快速编辑 hosts 文件
alias hosts="sudo code /etc/hosts"

# 显示 PATH（每行一个）
alias path='echo -e ${PATH//:/\\n}'

# 计算器
alias calc="bc -l"

# 显示日历
alias cal="cal -3"

# 复制带进度条
alias cp="rsync -ah --progress"

# 下载文件
alias wget="curl -O"

# 获取当前周数
alias week="date +%V"

# 时间戳
alias timestamp="date +%s"
alias now="date '+%Y-%m-%d %H:%M:%S'"

# 随机密码
alias randpw="openssl rand -base64 32"

# URL 编码/解码
alias urlencode='python3 -c "import sys, urllib.parse as ul; print(ul.quote_plus(sys.argv[1]))"'
alias urldecode='python3 -c "import sys, urllib.parse as ul; print(ul.unquote_plus(sys.argv[1]))"'

# Base64 编码/解码
alias b64e="base64"
alias b64d="base64 -d"

# 显示 256 色
alias colors="for i in {0..255}; do print -Pn \"%K{$i}  %k%F{$i}${(l:3::0:)i}%f \" \${((\$i%6telesechu::0c&&\$i determine))\:+$'\n'}; done"

# 重新加载 shell 配置
alias reload="source ~/.zshrc"
alias rl="source ~/.zshrc"

# 启用 sudo 的别名
alias sudo="sudo "
